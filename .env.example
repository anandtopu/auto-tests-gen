# --- LLM ---
ANTHROPIC_API_KEY=
# --- Adapter mode (1 = mock adapters for demos, 0 = real adapters) ---
AIQE_MOCK=1
# --- SSL verification (set to 0 on corporate networks with a custom CA / self-signed certs) ---
AIQE_SSL_VERIFY=1
# --- SCM (choose per estate; SCM_KIND=github|bitbucket|stash selects the adapter) ---
SCM_KIND=github
AIQE_STATUS_URL=              # URL the ai-qe PR build status links to (e.g. the dashboard)
GITHUB_TOKEN=                 # fine-grained: contents RW on feature branches only
BITBUCKET_TOKEN=              # Bitbucket Cloud app password / access token
STASH_URL=                    # Bitbucket Server/DC ("Stash") base URL, e.g. https://stash.company.com
STASH_PROJECT=                # project key, e.g. ENG
STASH_TOKEN=                  # HTTP access token (repo read + PR comment; RW for test repos)
# --- Atlassian Remote MCP (covers Jira + Confluence + Bitbucket) ---
JIRA_URL=                     # e.g. https://your-domain.atlassian.net (tracker REST fallback)
ATLASSIAN_MCP_URL=https://mcp.atlassian.com/v1/mcp
ATLASSIAN_MCP_TOKEN=          # service account API token (headless)
CONFLUENCE_URL=               # e.g. https://your-domain.atlassian.net/wiki (publish-plan)
CONFLUENCE_SPACE=QA           # default space for test-plan mirroring
# --- OpenHands (orchestrator, Path 1; used by make smoke-openhands) ---
OPENHANDS_URL=                # Agent Server base URL (enterprise/cloud)
OPENHANDS_API_KEY=
OPENHANDS_CONVERSATIONS_PATH= # /api/v1/app-conversations for Cloud; leave blank for self-hosted
AIQE_SANDBOX_IMAGE=ai-qe-sandbox:latest
AIQE_CONTROL_REPO=org/ai-qe-control
AIQE_SMOKE_TICKET=            # a real readable ticket for the smoke test (e.g. PROJ-123)
AIQE_SMOKE_REPO=              # a real repo with an open PR for the smoke test
AIQE_SMOKE_PR=

# --- CI/CD ---
JENKINS_URL=
JENKINS_USER=
JENKINS_API_TOKEN=
# --- Notify / Telemetry ---
NOTIFY_KIND=slack             # slack | email | both — which channel(s) get run notifications
SLACK_WEBHOOK_URL=
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=
# --- Email (SMTP) — run summaries, review digests, team reports ---
SMTP_HOST=                    # smtp.example.com (unset -> emails written to out/mock-email/)
SMTP_PORT=587
SMTP_SECURITY=starttls        # starttls | ssl | none
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=                    # ai-qe@example.com (defaults to SMTP_USER)
SMTP_TO=                      # default recipients, csv: qa-team@example.com,lead@example.com
# --- Budgets ---
MAX_COST_USD_PER_RUN=4.00
MAX_WALLCLOCK_MIN=25
